# Database
DATABASE_URL=postgresql://seked:sekedpass@localhost:5432/seked

# Redis
REDIS_URL=redis://localhost:6379

# Gateway
PORT=3000
NODE_ENV=production

# Authentication
ADMIN_API_KEY=sk-admin-1234567890abcdef
JWT_SECRET=your-jwt-secret-here

# Billing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Service Ports
GATEWAY_PORT=3000
SEKED_PORT=3002
CONVERGEOS_PORT=3001
ECOBE_PORT=3003
WATCHTOWER_PORT=3004
CELESTIAL_NAVIGATOR_PORT=3005
ACOUSTIC_LISTENER_PORT=3006
EMPIRE_COLLAPSE_PORT=3007
SHADOW_TRACKER_PORT=3008

# Signal Coherence AGI Configuration
SIGNAL_FIELD_PERSISTENCE=true
EMPIRE_COLLAPSE_PREVENTION=true
SHADOW_TRACKING_ENABLED=true
CELESTIAL_NAVIGATION_ENABLED=true
ACOUSTIC_LISTENING_ENABLED=true
WATCHTOWER_VALIDATION_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30000

# Rate Limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW=60000

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=1000

# Carbon Tracking
CARBON_TRACKING_ENABLED=true
CARBON_CREDIT_ENABLED=true

# Security
CORS_ORIGIN=*
HELMET_ENABLED=true
RATE_LIMIT_ENABLED=true

# Development
DEBUG=false
VERBOSE_LOGGING=false
